rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdminOrCashier() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'cashier'];
    }

    function paymentConfirmed(status) {
      return status in ['paid', 'confirmed'];
    }

    function ownsExisting() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function ownsIncoming() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    function bookingContractCreateValid() {
      return ownsIncoming()
        && request.resource.data.booking_id is string
        && request.resource.data.booking_source in ['website', 'mobile_app']
        && request.resource.data.payment_method == 'cash'
        && request.resource.data.payment_status == 'pay_at_counter'
        && request.resource.data.status == 'active';
    }

    function ownedCancelUpdateBase() {
      return ownsExisting()
        && ownsIncoming()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'updated_at', 'cancelled_at'])
        && request.resource.data.status == 'cancelled';
    }

    function ownedBookingCancelUpdate() {
      return ownedCancelUpdateBase()
        && resource.data.status == 'active';
    }

    function ownedMuseumTicketCancelUpdate() {
      return ownedCancelUpdateBase()
        && !(resource.data.status in ['used', 'cancelled', 'canceled', 'declined', 'rejected', 'archived', 'inactive', 'disabled', 'expired']);
    }

    function pairedRobotTicketCancelCleanup(ticketId) {
      // Bridge model: the robot's `status` is owned by the ROS2 bridge, so the
      // cancel cleanup only asserts the pairing mutex (`activeSessionId`) was held
      // by this session and is cleared afterwards. We never read or require the
      // robot `status`, and never touch the final-model fields.
      return resource.data.status in ['paired', 'in_progress']
        && resource.data.session_id is string
        && resource.data.session_id != ''
        && resource.data.paired_robot_id is string
        && resource.data.paired_robot_id != ''
        && exists(/databases/$(database)/documents/robots/$(resource.data.paired_robot_id))
        && get(/databases/$(database)/documents/robots/$(resource.data.paired_robot_id)).data.activeSessionId == resource.data.session_id
        && existsAfter(/databases/$(database)/documents/tourSessions/$(resource.data.session_id))
        && getAfter(/databases/$(database)/documents/tourSessions/$(resource.data.session_id)).data.status == 'cancelled'
        && getAfter(/databases/$(database)/documents/tourSessions/$(resource.data.session_id)).data.userId == request.auth.uid
        && getAfter(/databases/$(database)/documents/tourSessions/$(resource.data.session_id)).data.robot_tour_ticket_id == ticketId
        && existsAfter(/databases/$(database)/documents/robots/$(resource.data.paired_robot_id))
        && getAfter(/databases/$(database)/documents/robots/$(resource.data.paired_robot_id)).data.activeSessionId == null;
    }

    function ownedRobotTourTicketCancelUpdate(ticketId) {
      return ownedCancelUpdateBase()
        && !(resource.data.status in ['completed', 'cancelled', 'canceled', 'declined', 'rejected', 'archived', 'inactive', 'disabled', 'expired'])
        && (!(resource.data.status in ['paired', 'in_progress']) || pairedRobotTicketCancelCleanup(ticketId));
    }

    function usableTicketStatus(status) {
      return status in ['active', 'valid', 'confirmed'];
    }

    function activeOwnedMuseumTicket(ticketId) {
      return signedIn()
        && ticketId is string
        && exists(/databases/$(database)/documents/museumTickets/$(ticketId))
        && get(/databases/$(database)/documents/museumTickets/$(ticketId)).data.userId == request.auth.uid
        && usableTicketStatus(get(/databases/$(database)/documents/museumTickets/$(ticketId)).data.status)
        && paymentConfirmed(get(/databases/$(database)/documents/museumTickets/$(ticketId)).data.payment_status);
    }

    function activeOwnedRobotTourTicket(ticketId) {
      return signedIn()
        && ticketId is string
        && exists(/databases/$(database)/documents/robotTourTickets/$(ticketId))
        && get(/databases/$(database)/documents/robotTourTickets/$(ticketId)).data.userId == request.auth.uid
        && usableTicketStatus(get(/databases/$(database)/documents/robotTourTickets/$(ticketId)).data.status)
        && paymentConfirmed(get(/databases/$(database)/documents/robotTourTickets/$(ticketId)).data.payment_status);
    }

    function validTourSessionCreate(sessionId) {
      return validFinalTourSessionCreate(sessionId);
    }

    function validFinalTourSessionCreate(sessionId) {
      return ownsIncoming()
        && request.resource.data.session_id is string
        && request.resource.data.session_id == sessionId
        && request.resource.data.robotId is string
        && request.resource.data.booking_id is string
        && request.resource.data.museum_ticket_id is string
        && request.resource.data.robot_tour_ticket_id is string
        && activeOwnedMuseumTicket(request.resource.data.museum_ticket_id)
        && activeOwnedRobotTourTicket(request.resource.data.robot_tour_ticket_id)
        && request.resource.data.status in ['paired', 'active']
        && (request.resource.data.status == 'active' || request.resource.data.current_exhibit_id == null)
        && request.resource.data.current_exhibit_index == 0
        && request.resource.data.selected_exhibits is list
        && (request.resource.data.status == 'active' || request.resource.data.started_at == null)
        && request.resource.data.completed_at == null;
    }

    // Bridge model (single source of truth):
    // The robot document's status/robotConnectionState/mqttEnabled/lastSeenAt are
    // owned by the ROS2 bridge. The app only ever writes `activeSessionId` (set on
    // pair, cleared on release) plus an updated_at timestamp. `activeSessionId` is
    // the pairing mutex. The app never writes the robot's `status`.

    function validRobotPair(robotId) {
      return validBridgeRobotPair(robotId);
    }

    function validRobotRelease(robotId) {
      return validBridgeRobotRelease(robotId);
    }

    function robotIdMatchesBridgeContract(robotId) {
      return robotId == 'ROBOT-HORUS-001'
        || (('robotId' in request.resource.data) && request.resource.data.robotId == robotId);
    }

    function bridgeRobotUnpaired() {
      return !('activeSessionId' in resource.data)
        || resource.data.activeSessionId == null
        || (resource.data.activeSessionId is string && resource.data.activeSessionId.matches('^\\s*$'));
    }

    function bridgeRobotSessionOwner(sessionId, robotId) {
      return existsAfter(/databases/$(database)/documents/tourSessions/$(sessionId))
        && getAfter(/databases/$(database)/documents/tourSessions/$(sessionId)).data.userId == request.auth.uid
        && getAfter(/databases/$(database)/documents/tourSessions/$(sessionId)).data.robotId == robotId;
    }

    function bridgeSessionRobotTourTicketId(sessionId) {
      // Use Map.get() with a default so a missing key returns null instead of
      // raising a hard evaluation error. The pairing transaction writes the
      // session with snake_case `robot_tour_ticket_id` only; dotted access to a
      // non-existent `robotTourTicketId` would error and deny the whole commit.
      return getAfter(/databases/$(database)/documents/tourSessions/$(sessionId)).data
        .get('robotTourTicketId',
          getAfter(/databases/$(database)/documents/tourSessions/$(sessionId)).data
            .get('robot_tour_ticket_id', null));
    }

    function validBridgeRobotPair(robotId) {
      return signedIn()
        && robotIdMatchesBridgeContract(robotId)
        && resource.data.status == 'available'
        && resource.data.robotConnectionState == 'connected'
        && resource.data.mqttEnabled == true
        && bridgeRobotUnpaired()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['activeSessionId', 'updatedAt', 'updated_at'])
        && request.resource.data.activeSessionId is string
        && !request.resource.data.activeSessionId.matches('^\\s*$')
        && bridgeRobotSessionOwner(request.resource.data.activeSessionId, robotId);
    }

    function validBridgeRobotRelease(robotId) {
      return signedIn()
        && robotIdMatchesBridgeContract(robotId)
        && resource.data.activeSessionId is string
        && resource.data.activeSessionId != ''
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['activeSessionId', 'updatedAt', 'updated_at'])
        && request.resource.data.activeSessionId == null
        && exists(/databases/$(database)/documents/tourSessions/$(resource.data.activeSessionId))
        && get(/databases/$(database)/documents/tourSessions/$(resource.data.activeSessionId)).data.userId == request.auth.uid
        && get(/databases/$(database)/documents/tourSessions/$(resource.data.activeSessionId)).data.robotId == robotId;
    }

    function unpairedExistingTicket() {
      return (!('paired_robot_id' in resource.data) || resource.data.paired_robot_id == null || resource.data.paired_robot_id == '')
        && (!('session_id' in resource.data) || resource.data.session_id == null || resource.data.session_id == '');
    }

    function validRobotTourTicketPairUpdate(ticketId) {
      return ownsExisting()
        && ownsIncoming()
        && usableTicketStatus(resource.data.status)
        && paymentConfirmed(resource.data.payment_status)
        && unpairedExistingTicket()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'paired_robot_id', 'session_id', 'paired_at', 'updated_at'])
        && request.resource.data.status in ['paired', 'in_progress']
        && request.resource.data.paired_robot_id is string
        && request.resource.data.paired_robot_id != ''
        && request.resource.data.session_id is string
        && request.resource.data.session_id != ''
        && existsAfter(/databases/$(database)/documents/tourSessions/$(request.resource.data.session_id))
        && getAfter(/databases/$(database)/documents/tourSessions/$(request.resource.data.session_id)).data.userId == request.auth.uid
        && bridgeSessionRobotTourTicketId(request.resource.data.session_id) == ticketId
        && getAfter(/databases/$(database)/documents/tourSessions/$(request.resource.data.session_id)).data.robotId == request.resource.data.paired_robot_id
        && request.resource.data.paired_robot_id == 'ROBOT-HORUS-001';
    }

    function validRobotTourTicketStartUpdate(ticketId) {
      return ownsExisting()
        && ownsIncoming()
        && resource.data.status == 'paired'
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'updated_at'])
        && request.resource.data.status == 'in_progress'
        && existsAfter(/databases/$(database)/documents/tourSessions/$(resource.data.session_id))
        && getAfter(/databases/$(database)/documents/tourSessions/$(resource.data.session_id)).data.userId == request.auth.uid
        && getAfter(/databases/$(database)/documents/tourSessions/$(resource.data.session_id)).data.robot_tour_ticket_id == ticketId
        && getAfter(/databases/$(database)/documents/tourSessions/$(resource.data.session_id)).data.status == 'active';
    }

    function validRobotTourTicketCompleteUpdate(ticketId) {
      return ownsExisting()
        && ownsIncoming()
        && resource.data.status in ['paired', 'in_progress']
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'updated_at'])
        && request.resource.data.status == 'completed'
        && existsAfter(/databases/$(database)/documents/tourSessions/$(resource.data.session_id))
        && getAfter(/databases/$(database)/documents/tourSessions/$(resource.data.session_id)).data.userId == request.auth.uid
        && getAfter(/databases/$(database)/documents/tourSessions/$(resource.data.session_id)).data.robot_tour_ticket_id == ticketId
        && getAfter(/databases/$(database)/documents/tourSessions/$(resource.data.session_id)).data.status == 'completed';
    }

    function validTourSessionOwnerUpdate() {
      return ownsExisting()
        && ownsIncoming()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'status',
            'current_exhibit_id',
            'current_exhibit_index',
            'started_at',
            'completed_at',
            'updated_at',
            'robotState',
            'visitedExhibitIds',
            'commandStatus',
            'lastCommandId',
            'lastCommandType',
            'lastCommandError',
            'lastCommandAt',
            'lastAckAt',
            'lastRobotEvent',
            'lastRobotEventAt',
            'mqttEnabled',
            'robotConnectionState'
          ])
        && request.resource.data.status in ['paired', 'active', 'paused', 'completed', 'cancelled'];
    }

    function adminPaymentUpdate() {
      return isAdminOrCashier()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['payment_status', 'payment_confirmed_at', 'payment_confirmed_by', 'updated_at'])
        && request.resource.data.payment_status in ['confirmed', 'paid']
        && request.resource.data.payment_confirmed_by == request.auth.uid;
    }

    function ownedUserCreate(userId) {
      return signedIn()
        && userId == request.auth.uid
        && (!('role' in request.resource.data) || request.resource.data.role == null);
    }

    function ownedUserProfileUpdate(userId) {
      return signedIn()
        && userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'uid',
            'email',
            'full_name',
            'display_name',
            'phone_number',
            'nationality',
            'preferred_language',
            'avatar_url',
            'accessibility_defaults',
            'marketing_opt_in',
            'created_at',
            'updated_at',
            'last_seen_at'
          ]);
    }

    match /users/{userId} {
      allow read: if signedIn() && userId == request.auth.uid;
      allow create: if ownedUserCreate(userId);
      allow update: if ownedUserProfileUpdate(userId);
      allow delete: if false;
    }

    match /bookings/{bookingId} {
      allow read: if ownsExisting() || isAdminOrCashier();
      allow create: if bookingContractCreateValid();
      allow update: if ownedBookingCancelUpdate() || adminPaymentUpdate();
      allow delete: if false;
    }

    match /museumTickets/{ticketId} {
      allow read: if ownsExisting() || isAdminOrCashier();
      allow create: if bookingContractCreateValid();
      allow update: if ownedMuseumTicketCancelUpdate() || adminPaymentUpdate();
      allow delete: if false;
    }

    match /robotTourTickets/{ticketId} {
      allow read: if ownsExisting() || isAdminOrCashier();
      allow create: if bookingContractCreateValid();
      allow update: if ownedRobotTourTicketCancelUpdate(ticketId)
        || adminPaymentUpdate()
        || validRobotTourTicketPairUpdate(ticketId)
        || validRobotTourTicketStartUpdate(ticketId)
        || validRobotTourTicketCompleteUpdate(ticketId);
      allow delete: if false;
    }

    match /tourSessions/{sessionId} {
      allow read: if ownsExisting();
      // Prototype client pairing rule. Production should move pairing to a
      // Cloud Function/server endpoint so robot assignment is authoritative.
      allow create: if validTourSessionCreate(sessionId);
      allow update: if validTourSessionOwnerUpdate();
      allow delete: if false;
    }

    match /questions/{questionId} {
      allow read: if ownsExisting();
      allow create: if ownsIncoming()
        && request.resource.data.source == 'app'
        && request.resource.data.reason == 'voice_noise_fallback'
        && request.resource.data.status == 'pending';
      allow update, delete: if false;
    }

    match /photos/{photoId} {
      allow read: if ownsExisting();
      allow create: if ownsIncoming()
        && request.resource.data.type == 'robot_capture';
      allow update: if ownsExisting();
      allow delete: if false;
    }

    match /exhibits/{exhibitId} {
      allow read: if true;
      allow write: if false;
    }

    match /robots/{robotId} {
      allow read: if signedIn();
      // Bridge model: the app may only set or clear `activeSessionId`. The robot's
      // status/connection fields are owned by the ROS2 bridge, never the client.
      allow update: if validRobotPair(robotId)
        || validRobotRelease(robotId);
      allow create, delete: if false;
    }
  }
}
